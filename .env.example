# Порт локального Next.js frontend.
PORT=3000

# Хосты, с которых Next.js принимает Server Actions в development.
# Указываются без схемы: host:port.
SERVER_ACTIONS_ALLOWED_ORIGINS=localhost:3000,127.0.0.1:3000

# Базовый HTTP(S)-адрес backend API, доступный браузеру.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Базовый WS(S)-адрес backend для WebSocket-подключений.
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# Публичный ключ Clerk instance. Безопасен для браузера; обычно начинается с pk_test_ или pk_live_.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Секретный ключ той же Clerk instance для server-side middleware Next.js.
# Не публиковать и не коммитить реальное значение; начинается с sk_test_ или sk_live_.
CLERK_SECRET_KEY=sk_test_replace_me

# Необязательный адрес уже запущенного frontend для Playwright.
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Необязательный порт frontend, который Playwright запускает сам.
# PLAYWRIGHT_PORT=3000
